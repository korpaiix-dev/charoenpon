# ==============================================
# บริษัทเจริญพร - Environment Variables
# ==============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=charoenpon
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@postgres:5432/charoenpon

# --- Telegram Bot Tokens ---
SALES_BOT_TOKEN=your_sales_bot_token
GUARDIAN_BOT_TOKEN=your_guardian_bot_token
ADMIN_BOT_TOKEN=your_admin_bot_token

# --- Telegram Admin IDs (comma-separated) ---
ADMIN_TELEGRAM_IDS=123456789,987654321

# --- Discord ---
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id
DISCORD_ALERT_CHANNEL_ID=your_alert_channel_id
DISCORD_FINANCE_CHANNEL_ID=your_finance_channel_id
DISCORD_LOG_CHANNEL_ID=your_log_channel_id

# --- OpenRouter (AI API) ---
OPENROUTER_API_KEY=your_openrouter_api_key

# --- Google Sheets Service Account ---
GOOGLE_SHEETS_CREDENTIALS=credentials/google_sheets_sa.json
SHEETS_COST_WEBHOOK=

# --- Facebook Marketing API ---
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_AD_ACCOUNT_ID=act_your_ad_account_id
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_APP_SECRET=your_app_secret

# --- PromptPay ---
PROMPTPAY_PHONE=0812345678
PROMPTPAY_NAME=บริษัทเจริญพร

# --- TrueWallet ---
TRUEWALLET_PHONE=0812345678

# --- DigitalOcean Spaces (Backup / Media) ---
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_BUCKET=charoenpon-backup
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# --- Webhook (if using webhook mode instead of polling) ---
WEBHOOK_DOMAIN=charoenpon.com
WEBHOOK_PORT=8443

# --- Database Pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
SQL_ECHO=false

# --- Exchange Rate ---
USD_THB_FALLBACK=35.0
